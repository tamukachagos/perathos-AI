# Launch Desk — environment.
#
# CRITICAL: every value here is OPTIONAL. With NONE of them set the app builds
# and runs end-to-end in MOCK mode: an in-memory repository (seeded with the
# Maboneng sample) backs persistence, and a dev/auto auth path replaces email
# magic links. Setting DATABASE_URL flips persistence to Postgres with ZERO code
# change; adding the AUTH_* + EMAIL_* vars enables real magic-link sign-in.

# --- Persistence (M1) -------------------------------------------------------
# A real Vercel Postgres (Neon) connection string. When set to a postgres:// URL
# the data-access factory uses the Prisma repository. Unset (or left at the
# placeholder) => in-memory mock repository. `next build` never connects to it.
# DATABASE_URL="postgresql://user:password@host:5432/launchdesk?sslmode=require"

# --- Auth.js v5 (M1) --------------------------------------------------------
# Required ONLY for production magic-link auth. In mock mode a dev secret is used
# and the dev credentials / auto-session path is active instead.
# Generate with: npx auth secret   (or: openssl rand -base64 32)
# AUTH_SECRET="replace-with-a-32-byte-random-secret"

# Public base URL used for magic-link callbacks and absolute site links.
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Email provider (magic-link delivery) ----------------------------------
# Auth.js Nodemailer provider settings. Only needed when a real DB + AUTH_SECRET
# are configured; otherwise the dev auth path needs no email at all.
# EMAIL_SERVER="smtp://user:password@smtp.example.com:587"
# EMAIL_FROM="Launch Desk <no-reply@launchdesk.co.za>"

# --- Adapter mode (M0) ------------------------------------------------------
# Global default action-plane mode for the nine provider adapters.
# One of: mock | sandbox | live. Defaults to "mock".
# LAUNCH_DESK_ADAPTER_MODE="mock"

# --- POPIA: retention, Cron + DSAR (M5) -------------------------------------
# Lead retention window in months. Defaults to 12. The daily purge Cron
# (/api/cron/purge, scheduled in vercel.json) deletes leads past this.
# LAUNCH_DESK_RETENTION_MONTHS="12"

# Bearer token Vercel Cron must present to invoke the purge endpoint. Unset =>
# the endpoint is OPEN (mock/dev). Set it in production so only Vercel Cron can
# trigger a purge. Vercel sends it automatically as `Authorization: Bearer ...`.
# CRON_SECRET="replace-with-a-random-secret"

# Bearer token for the privileged DSAR endpoint (/api/dsar). Falls back to
# CRON_SECRET when unset; unset => the endpoint is OPEN (mock/dev only).
# DSAR_SECRET="replace-with-a-random-secret"

# Information Officer contact, surfaced on the /privacy page. Safe defaults are
# used in mock mode.
# LAUNCH_DESK_IO_NAME="Jane Dlamini"
# LAUNCH_DESK_IO_EMAIL="privacy@yourbusiness.co.za"
# LAUNCH_DESK_IO_PARTY="Your Business (Pty) Ltd"

# --- AI: Claude AgentProvider (onboarding profile generation) ---------------
# OPTIONAL. With ANTHROPIC_API_KEY UNSET the onboarding wizard's profile
# generation runs in MOCK mode (deterministic keyword heuristic, no network).
# Setting the key activates the real Claude call (Anthropic Messages API) that
# turns a plain-language business description into the structured profile — no UI
# or call-site change. On any API error the wizard falls back to the mock. The
# key is read only server-side (the profile route + AgentProvider action) and is
# never logged.
# ANTHROPIC_API_KEY="sk-ant-xxx"
# Override the model id. Defaults to claude-sonnet-4-6. Other current ids:
# claude-opus-4-8, claude-haiku-4-5-20251001. (Do NOT use any claude-3-* id.)
# ANTHROPIC_MODEL="claude-sonnet-4-6"

# --- LLM router (W3 — src/integrations/llm) ---------------------------------
# OPTIONAL, all of it. The router is the single chokepoint for every LLM call.
# Provider selection (mirrors the dormant pattern): OPENROUTER_API_KEY → OpenRouter
# (OpenAI-compatible Chat Completions; one billing relationship for OSS + frontier
# models; returns native token usage + cost for metering); else ANTHROPIC_API_KEY
# (above) → direct Anthropic; else a DETERMINISTIC MOCK with synthetic usage so the
# whole routing + metering UX is exercisable with NO keys.
# OPENROUTER_API_KEY="sk-or-xxx"

# Per-tier model overrides. Each PREPENDS to the built-in primary + fallbacks
# (it never replaces them), so an operator can pin a churn-prone OSS slug without
# losing the vetted fallbacks behind it. OSS slugs (OpenRouter) move fastest —
# that is exactly why the policy is env-overridable, not hardcoded.
#   CHEAP   → profile.extract / classify.intent / copy.generate
#   CODE    → site.codegen / site.codefix      (default claude-sonnet-4-6)
#   PREMIUM → reason.plan / security.review     (default claude-opus-4-8)
#   IMAGE   → image.generate / image.edit       (STUBBED sub-adapter for now)
# LLM_MODEL_CHEAP="meta-llama/llama-3.3-70b-instruct"
# LLM_MODEL_CODE="claude-sonnet-4-6"
# LLM_MODEL_PREMIUM="claude-opus-4-8"
# LLM_MODEL_IMAGE="google/gemini-2.5-flash-image"

# Cost/metering knobs (ZAR micro-cents; 1 cent = 1_000 micro). All optional —
# defaults keep the mock + Anthropic cost synthesis meaningful. FX buffer converts
# OpenRouter's native USD cost to ZAR.
# LLM_FX_ZAR_PER_USD="18.5"
# LLM_MOCK_RATE_PER_1K_MICRO="500"          # mock wholesale ≈ R0.005 / 1k tokens
# LLM_IMAGE_COST_MICRO="2000000"            # stub image wholesale ≈ R20 / image
# LLM_ANTHROPIC_IN_PER_1K_MICRO="9250"      # Anthropic input cost / 1k tokens
# LLM_ANTHROPIC_OUT_PER_1K_MICRO="46250"    # Anthropic output cost / 1k tokens

# --- Billing: Paystack subscriptions (M6) -----------------------------------
# OPTIONAL. With PAYSTACK_SECRET_KEY UNSET the billing flow runs in MOCK mode:
# "upgrade" instantly simulates an active subscription (NO real charge) and the
# Paystack webhook signature check is a stub that accepts. Setting the secret
# key activates real card charging (Paystack REST API) + HMAC-SHA512 webhook
# verification — no UI or call-site change. The key is read only server-side
# (checkout + webhook).
# PAYSTACK_SECRET_KEY="sk_live_or_test_xxx"
# PAYSTACK_PUBLIC_KEY="pk_live_or_test_xxx"
# Paystack plan codes that map our paid tiers to recurring Paystack plans. Create
# the plans in the Paystack dashboard (priced in ZAR to match the catalog) and
# paste their plan codes here. Required for recurring subscriptions; if unset, a
# paid checkout is a one-off transaction instead of a subscription.
# PAYSTACK_PLAN_GROWTH="PLN_xxxxxxxxxxxx"
# PAYSTACK_PLAN_PRO="PLN_xxxxxxxxxxxx"

# --- Multi-domain registrars (W4 — src/integrations/domain) -----------------
# OPTIONAL, all of it. With NONE set the RegistrarRouter uses deterministic MOCK
# backends (no network, no keys): .co.za / *.za route to a ZACR-style SA
# registrar mock and .com / other gTLDs route to a gTLD-reseller mock.
# checkAvailability returns deterministic availability + a ZAR price from the
# pricing config below. Setting a registrar's key activates its (future) live
# adapter behind the SAME RegistrarBackend interface; keys are operator secrets,
# read ONLY in the server action plane, never logged.
#
# ZACR-accredited SA registrar (.co.za / *.za) — e.g. Domains.co.za / Diamatrix.
# REGISTRAR_ZA_API_KEY="..."
# REGISTRAR_ZA_API_URL="https://api.your-za-registrar.example"
# International gTLD reseller (.com / .net / .io / …) — e.g. Namecheap / Gandi /
# OpenSRS / Cloudflare Registrar.
# REGISTRAR_GTLD_API_KEY="..."
# REGISTRAR_GTLD_API_URL="https://api.your-gtld-reseller.example"
#
# AES-256-GCM key for encrypting the domain transfer auth-code (auth-info) at
# rest. Accepts 32-byte hex (64 chars), 32-byte base64, or any passphrase
# (hashed to 32 bytes). REQUIRED in production for real transfers; in dev/mock a
# stable dev key is used so the flow runs with no secret. Read only server-side.
# Generate with: openssl rand -hex 32
# DOMAIN_AUTHCODE_KEY="replace-with-a-32-byte-key"
#
# Resale pricing (ZAR cents, integer). Defaults follow ENTERPRISE_REVIEW §8:
# .co.za sells R149 (wholesale ~R80); .com sells R249 (wholesale ~R185). The
# retail markup the wallet meters comes from LD_MARKUP_DOMAIN (above).
# LD_DOMAIN_ZA_PRICE_CENTS="14900"
# LD_DOMAIN_ZA_COST_CENTS="8000"
# LD_DOMAIN_GTLD_PRICE_CENTS="24900"
# LD_DOMAIN_GTLD_COST_CENTS="18500"

# --- Google Business Profile (W8 / B1 - src/integrations/localListing) -------
# OPTIONAL, all of it. With NONE set, GBP runs in MOCK mode: gbp.create returns
# 202 + an OperationRef and the listing settles pending_verification -> live via
# the W1 reconcile sweep (no network, no keys); gbp.sync is a no-op confirmation.
# Setting these activates the (future) real Google Business Profile API adapter
# behind the SAME LocalListingProvider interface. Keys are operator secrets, read
# ONLY in the server action plane, never logged. The NAP (name/area/phone) is the
# single source derived from the business profile (also used in on-site JSON-LD).
# GOOGLE_GBP_CLIENT_ID="..."
# GOOGLE_GBP_CLIENT_SECRET="..."
# GOOGLE_GBP_REFRESH_TOKEN="..."
# GOOGLE_GBP_ACCOUNT_ID="accounts/1234567890"

# --- WhatsApp commerce BSP (W8 / B2 - src/integrations/messaging/whatsapp) ---
# OPTIONAL, all of it. With NONE set, WhatsApp commerce runs in MOCK mode:
# whatsapp.publishCatalog confirms a catalog upload, whatsapp.sendMessage /
# sendTemplate meter the wallet per Meta's 2025 per-template model (service
# replies inside the 24h window are FREE, marketing/utility/auth templates are
# charged), and whatsapp.createPaymentLink builds a ZAR link on the platform
# origin. wa.me click-to-chat stays the FREE default and needs none of this.
# Setting a provider's keys activates the real Meta BSP send behind the SAME
# MessagingProvider interface (Clickatell / 360dialog / Twilio). Operator
# secrets, server-action-plane only, never logged.
# WHATSAPP_BSP_PROVIDER="360dialog"        # one of: clickatell | 360dialog | twilio
# WHATSAPP_BSP_API_KEY="..."
# WHATSAPP_BSP_API_URL="https://waba.360dialog.io"
# WHATSAPP_BSP_PHONE_NUMBER_ID="..."        # Meta WABA phone-number id
# WHATSAPP_BSP_WEBHOOK_SECRET="..."         # verifies inbound delivery/status webhooks
#
# Per-message wholesale cost overrides (ZAR micro-cents; 1 cent = 1_000 micro).
# Defaults model Meta's 2025 per-template rate card (placeholders, re-priceable
# without a deploy). Service-window replies are always free regardless of these.
# LD_WA_COST_UTILITY_MICRO="14000"          # ~R0.14 / utility template message
# LD_WA_COST_AUTH_MICRO="14000"             # ~R0.14 / authentication message
# LD_WA_COST_MARKETING_MICRO="50000"        # ~R0.50 / marketing message
# Retail markup the wallet meters on each charged message (default 2.0x).
# LD_MARKUP_WHATSAPP="2.0"

# --- GitHub + Vercel per-customer repos & deploys (W6 — §5.3) ---------------
# OPTIONAL, all of it. With NONE set, W6 runs in MOCK mode end-to-end (no
# network, no keys): github.createRepo returns a deterministic synthetic repo
# under the operator org, github.commit returns a synthetic sha, hosting.deploy
# returns 202 + an OperationRef and the deploy settles queued -> live via the W1
# reconcile sweep (the live path is the signed Vercel webhook below). GitHub is
# the SINGLE SOURCE OF TRUTH across all tiers; only the deploy target differs.
#
# GitHub App (dormant) — the operator-owned App that creates one private repo per
# customer site under GITHUB_APP_ORG (default "launchdesk-sites"). Installation
# tokens are minted per task, server-side only, never logged, never held by an
# agent/LLM. Setting these activates the (future) real GitHub App adapter behind
# the SAME GitHubProvider interface.
# GITHUB_APP_ID="123456"
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_APP_INSTALLATION_ID="12345678"
# GITHUB_APP_ORG="launchdesk-sites"
#
# Secret GitHub signs webhooks with (HMAC-SHA256 over the raw body, sent as
# `x-hub-signature-256`). The GitHub webhook route is a fail-closed STUB in W6
# (the Vercel webhook settles the deploy); push/workflow_run events drive the
# container/K8s build + agent team in Phase 3. FAIL CLOSED in production-non-mock.
# GITHUB_WEBHOOK_SECRET="replace-with-a-random-secret"

# Vercel (dormant) — the StaticTier deploy target. Setting these activates the
# (future) real Vercel API adapter behind the SAME HostingProvider interface
# (create project + deploy hook per repo). Operator secrets, server-action-plane
# only, never logged.
# VERCEL_TOKEN="..."
# VERCEL_TEAM_ID="team_xxx"
# VERCEL_PROJECT_PREFIX="launchdesk"
#
# Secret Vercel signs deploy webhooks with (HMAC-SHA1 over the raw body, sent as
# `x-vercel-signature`). FAIL CLOSED: unset => the webhook is OPEN only in
# dev/mock; in production-non-mock a missing secret REJECTS (401). Set it in
# production so only Vercel can settle a deploy. deployment.succeeded /
# deployment.error settle the W1 op to live/failed + update the Deployment row.
# VERCEL_WEBHOOK_SECRET="replace-with-a-random-secret"

# --- Observability: Sentry (M5) ---------------------------------------------
# OPTIONAL. With SENTRY_DSN UNSET, Sentry is a no-op and `@sentry/nextjs` is
# never imported — mock mode stays clean and the build needs no secrets. Set the
# DSN to enable error reporting; the structured logger (no PII) runs regardless.
# SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
