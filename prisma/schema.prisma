// ---------------------------------------------------------------------------
// GlobalPricingPlan — per-currency plan pricing catalog. Enables localised
// pricing (e.g. ZAR, NGN, KES) and maps each plan/currency pair to its
// Stripe Price id or Paystack plan code for checkout.
// ---------------------------------------------------------------------------

model GlobalPricingPlan {
  id               String   @id @default(cuid())
  planKey          String
  currency         String
  priceCents       Int
  stripePriceId    String?
  paystackPlanCode String?
  createdAt        DateTime @default(now())

  @@unique([planKey, currency])
  @@index([currency])
}
