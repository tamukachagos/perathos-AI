// Launch Desk — M1 persistence schema.
//
// Provider is postgresql. The app MUST still build and run with NO DATABASE_URL
// (mock mode): nothing here is loaded at build/static-generation time, and the
// generated client is only instantiated by the Prisma repository impl, which the
// env-gated factory selects only when DATABASE_URL is set.
//
// Tenant isolation is enforced in two layers:
//   1. App layer  — every query is scoped by `tenantId` via src/lib/authz.ts.
//   2. DB layer    — Postgres Row-Level Security policies (see the initial
//      migration's RLS SQL) are a backstop that closes cross-tenant IDOR even
//      if an app-layer scope is missed.
//
// Every tenant-owned table carries a `tenantId` column + index so both layers
// can scope efficiently.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity — Auth.js (NextAuth) v5 with the Prisma adapter + DB sessions.
// These four models match the Auth.js Prisma adapter schema exactly.
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Tenancy — a Tenant is the organization that owns all business data. A User
// joins one or more Tenants through a Membership (role-bearing). The active
// tenant is resolved from the session in authz.ts.
// ---------------------------------------------------------------------------

enum MembershipRole {
  owner
  admin
  member
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships         Membership[]
  businesses          Business[]
  generatedSites      GeneratedSite[]
  siteVersions        SiteVersion[]
  domains             Domain[]
  paymentLinks        PaymentLink[]
  leads               Lead[]
  adapterConnections  AdapterConnection[]
  auditLog            AuditLog[]
  subscription        Subscription?
  approvalNonces      ApprovalNonce[]
  operations          Operation[]
  tokenWallet         TokenWallet?
  usageRecords        UsageRecord[]
  invoices            Invoice[]
  localListings       LocalListing[]
  products            Product[]
  whatsappOrders      WhatsappOrder[]
  siteRepos           SiteRepo[]
  deployments         Deployment[]
  hostingDeployments  HostingDeployment[]
  provisioningJobs    ProvisioningJob[]
  agentJobs           AgentJob[]
  agentPolicy         AgentPolicy?

  @@map("tenants")
}

model Membership {
  id        String         @id @default(cuid())
  tenantId  String
  userId    String
  role      MembershipRole @default(owner)
  createdAt DateTime       @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId])
  @@map("memberships")
}

// ---------------------------------------------------------------------------
// Business — the plain-language profile the dashboard edits. Mirrors the
// `Business` shape in src/lib/types.ts (one tenant can own several businesses).
// ---------------------------------------------------------------------------

model Business {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  industry    String   @default("")
  location    String   @default("")
  whatsapp    String   @default("")
  domainName  String   @default("")
  email       String   @default("")
  tone        String   @default("")
  offer       String   @default("")
  services    String   @default("")
  locale      String   @default("en")
  currency    String   @default("USD")
  region      String   @default("us-east")
  timezone    String   @default("UTC")
  countryCode String   @default("US")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  generatedSites GeneratedSite[]
  domains        Domain[]
  paymentLinks   PaymentLink[]
  leads          Lead[]
  localListings  LocalListing[]
  products       Product[]
  whatsappOrders WhatsappOrder[]

  @@index([tenantId])
  @@map("businesses")
}

// ---------------------------------------------------------------------------
// GeneratedSite + SiteVersion — a published site for a business, with an
// append-style version history (rollback target for M2). The current published
// content is the SiteVersion referenced by `currentVersionId`.
// ---------------------------------------------------------------------------

enum SiteStatus {
  draft
  published
  archived
}

model GeneratedSite {
  id               String     @id @default(cuid())
  tenantId         String
  businessId       String
  // S7: slug uniqueness is PER TENANT (not global) so tenants cannot squat each
  // other's business-name slug. Public host→slug resolution still finds one
  // published site per slug.
  slug             String
  status           SiteStatus @default(draft)
  currentVersionId String?    @unique
  publishedAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business       Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  versions       SiteVersion[] @relation("SiteVersions")
  currentVersion SiteVersion?  @relation("CurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([businessId])
  @@index([slug])
  @@map("generated_sites")
}

model SiteVersion {
  id        String   @id @default(cuid())
  tenantId  String
  siteId    String
  version   Int
  // The full PublishedSite payload (servicesList, launchRecord, profile fields)
  // captured at publish time, kept verbatim for crawlable SSR + rollback.
  snapshot  Json
  createdAt DateTime @default(now())

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site        GeneratedSite  @relation("SiteVersions", fields: [siteId], references: [id], onDelete: Cascade)
  currentFor  GeneratedSite? @relation("CurrentVersion")

  @@unique([siteId, version])
  @@index([tenantId])
  @@index([siteId])
  @@map("site_versions")
}

// ---------------------------------------------------------------------------
// Domain — a custom .co.za domain mapped to a site (host→slug in Edge middleware,
// M2/M4). Registration is async; `status` tracks the lifecycle.
// ---------------------------------------------------------------------------

// W4: transfer_pending + expiring added to the lifecycle (multi-domain).
enum DomainStatus {
  requested
  pending_registration
  transfer_pending
  active
  expiring
  failed
  released
}

model Domain {
  id         String       @id @default(cuid())
  tenantId   String
  businessId String?
  hostname   String       @unique
  status     DomainStatus @default(requested)

  // W4 multi-domain (registrar-agnostic) fields. The model is otherwise
  // TLD-neutral; these carry the registrar routing + lifecycle + pricing state.
  // `tld` is the matched public suffix (e.g. "co.za", "com"); `registrar` is the
  // backend kind ("za" | "gtld"). `registrarRef` is the backend-side id.
  tld          String?
  registrar    String?
  registrarRef String?
  autoRenew    Boolean   @default(false)
  expiresAt    DateTime?
  // EPP / transfer auth-info code, stored ENCRYPTED (AES-256-GCM) — never plain,
  // never logged. See src/integrations/domain/fieldCrypto.ts.
  authCode     String?
  // Resale economics snapshot at request time, ZAR cents (integer).
  costCents    Int?
  priceCents   Int?
  // The async W1 operation that registers/transfers/renews this domain.
  operationId  String?

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([businessId])
  @@map("domains")
}

// ---------------------------------------------------------------------------
// PaymentLink — a hosted payment link configured per business (Paystack/Yoco/
// PayFast in M4). Launch Desk never stores card data.
// ---------------------------------------------------------------------------

enum PaymentLinkStatus {
  draft
  active
  disabled
}

model PaymentLink {
  id          String            @id @default(cuid())
  tenantId    String
  businessId  String
  label       String
  amountCents Int?
  currency    String            @default("ZAR")
  provider    String            @default("paystack")
  url         String?
  status      PaymentLinkStatus @default(draft)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([businessId])
  @@map("payment_links")
}

// ---------------------------------------------------------------------------
// Lead — a POPIA-compliant enquiry captured by a published site's lead form.
// Consent is captured + timestamped, the processing purpose is recorded, the
// marketing opt-in is separate, and a retention/expiry timestamp drives the
// POPIA purge Cron (M5).
// ---------------------------------------------------------------------------

model Lead {
  id            String    @id @default(cuid())
  tenantId      String
  businessId    String
  name          String
  contact       String
  message       String    @default("")
  purpose       String    @default("Respond to this enquiry")
  consent       Boolean   @default(false)
  consentAt     DateTime?
  marketingOptIn Boolean  @default(false)
  // POPIA retention: when this lead may be purged. Defaults applied at write time.
  retentionUntil DateTime?
  createdAt     DateTime  @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([businessId])
  @@index([retentionUntil])
  @@map("leads")
}

// ---------------------------------------------------------------------------
// AdapterConnection — per-tenant state/mode for each of the nine provider
// adapters. Mode mirrors AdapterMode (mock | sandbox | live). Secrets are NOT
// stored here (they live in env, read only in the server execute plane).
// ---------------------------------------------------------------------------

enum AdapterConnMode {
  mock
  sandbox
  live
}

enum AdapterConnStatus {
  ready
  review
  pending
}

model AdapterConnection {
  id            String            @id @default(cuid())
  tenantId      String
  interfaceName String
  mode          AdapterConnMode   @default(mock)
  status        AdapterConnStatus @default(pending)
  // Non-secret adapter state (e.g. external resource ids, last sync ref).
  state         Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, interfaceName])
  @@index([tenantId])
  @@map("adapter_connections")
}

// ---------------------------------------------------------------------------
// Subscription — a tenant's billing plan + lifecycle state (M6). One per tenant.
// A tenant with NO row is on the Free plan by default (entitlementsFor("free")).
// Card data is NEVER stored here; only the provider's subscription reference.
// In mock mode this is simulated end-to-end; with Paystack keys the same shape
// is driven by checkout + signature-verified webhook events.
// ---------------------------------------------------------------------------

enum SubscriptionPlan {
  free
  growth
  pro
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  incomplete
}

model Subscription {
  id                     String             @id @default(cuid())
  tenantId               String             @unique
  plan                   SubscriptionPlan   @default(free)
  status                 SubscriptionStatus @default(active)
  currentPeriodEnd       DateTime?
  provider               String             @default("mock")
  providerSubscriptionId String?
  cancelAtPeriodEnd      Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([provider, providerSubscriptionId])
  @@map("subscriptions")
}

// ---------------------------------------------------------------------------
// W1 reliability stores — persistent backing for the approval nonce ledger, the
// async operation store, and the webhook dedup ledger. These were previously
// in-memory `globalThis` maps (B1/B7/B8), which break on serverless: approvals
// fail as "already used", async ops 404 on poll, webhooks re-apply. Persisting
// them with ATOMIC compare-and-set on consume (UPDATE ... WHERE consumed_at IS
// NULL returning rowcount) makes single-use survive concurrency + multi-process.
//
// These tables are tenant-scoped and RLS-protected (see the W1 migration). They
// are only ever touched by the Prisma store impl, selected when DATABASE_URL is
// real; in mock mode the in-memory impl is used and these tables are never read.
// ---------------------------------------------------------------------------

// The single-use approval nonce ledger. consumedAt is the atomic claim marker:
// the first UPDATE that flips it from NULL wins; a replay finds it non-NULL.
model ApprovalNonce {
  nonce          String    @id
  tenantId       String
  verb           String
  payloadHash    String
  idempotencyKey String
  issuedAt       DateTime  @default(now())
  expiresAt      DateTime
  consumedAt     DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([expiresAt])
  @@map("approval_nonces")
}

// An async operation (domain.register / hosting.deploy / email.provision).
// Idempotency is PER TENANT now (B7): the unique key is (tenantId, idempotencyKey)
// so two tenants reusing the UI default "idem-1" no longer leak each other's op.
model Operation {
  id             String   @id
  tenantId       String
  verb           String
  target         String
  status         String   @default("pending")
  detail         String
  idempotencyKey String
  settleAt       DateTime
  result         Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([status])
  @@map("operations")
}

// Webhook dedup ledger (B8/B13): one row per processed event id. The unique
// constraint is the exactly-once guarantee — a redelivery hits the conflict.
model WebhookEvent {
  id        String   @id @default(cuid())
  provider  String
  eventId   String
  createdAt DateTime @default(now())

  @@unique([provider, eventId])
  @@index([provider])
  @@map("webhook_events")
}

// ---------------------------------------------------------------------------
// W2 metering wallet — the prepaid credit wallet + append-only usage ledger +
// rolled invoices (§5.4 / §8). One unified ledger serves LLM tokens, hosting
// hours, and domains alike; the wallet balance is the universal hard ceiling
// enforced as a pre-flight check at the ActionRouter.
//
// All three tables are tenant-owned → RLS (ENABLE + FORCE + tenant_isolation),
// mirroring M1/W1. Only ever touched by the Prisma store impl (DATABASE_URL
// real); in mock mode the in-memory wallet store is used and these are unread.
//
// Money is stored in ZAR MICRO-CENTS (BigInt): 1 cent = 1_000 micro, so
// R1 = 100_000 micro. Micro-cents keep per-token retail prices (fractions of a
// cent) exact without floating point.
// ---------------------------------------------------------------------------

// One wallet per tenant. balanceMicro is the cached running total (prepaid).
// Credits raise it (top-up), debits lower it (recordUsage), both atomically.
model TokenWallet {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  balanceMicro BigInt   @default(0)
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("token_wallets")
}

// Append-only billing source of truth: one row per metered event. Exactly-once
// accounting is enforced by @@unique([tenantId, idempotencyKey]) — a duplicate
// record is a no-op that returns the prior row (never double-debits).
model UsageRecord {
  id             String   @id @default(cuid())
  tenantId       String
  // e.g. "llm.profile.extract" | "hosting.cpu_hour" | "domain.register".
  kind           String
  quantity       Int      @default(1)
  // Wholesale unit cost (what the operator pays upstream), ZAR micro-cents.
  unitCostMicro  BigInt   @default(0)
  // Retail unit price = round(unitCostMicro * marginMultiplier), micro-cents.
  unitPriceMicro BigInt   @default(0)
  // Total debited = unitPriceMicro * quantity, micro-cents.
  amountMicro    BigInt   @default(0)
  // Billing period this event rolls into, e.g. "2026-06" (YYYY-MM).
  period         String
  idempotencyKey String
  createdAt      DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([tenantId, period])
  @@map("usage_records")
}

enum InvoiceStatus {
  open
  paid
  void
}

// A period's usage rolled into a single invoice, charged via the dormant
// Paystack BillingProvider (mock now). One per (tenant, period).
model Invoice {
  id                String        @id @default(cuid())
  tenantId          String
  period            String
  totalMicro        BigInt        @default(0)
  status            InvoiceStatus @default(open)
  providerInvoiceId String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, period])
  @@index([tenantId])
  @@index([tenantId, period])
  @@map("invoices")
}

// ---------------------------------------------------------------------------
// AuditLog — append-only record of every risky action / state change. No
// updates or deletes (enforced by RLS in the migration). Drives the audit UI
// and the ActionRouter audit sink (M3).
// ---------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  // Structured, PII-free detail about the event.
  metadata   Json?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([createdAt])
  @@map("audit_log")
}

// ---------------------------------------------------------------------------
// W8 — Google Business Profile automation (B1) + WhatsApp commerce (B2).
//
// All three are tenant-owned → RLS (ENABLE + FORCE + tenant_isolation), the
// same backstop as every other tenant table. Only the Prisma store impl ever
// touches them (DATABASE_URL real); in mock mode the in-memory store is used.
// Money (priceCents / totalCents) is ZAR cents stored as BigInt so a large
// catalog/order total never loses precision.
// ---------------------------------------------------------------------------

// The GBP listing lifecycle. Google verification is async; status tracks it.
enum LocalListingStatus {
  draft
  pending_verification
  live
  failed
}

// A tenant-owned Google Business Profile listing. NAP (name/area/phone) is the
// SINGLE SOURCE derived from the Business profile (also used in JSON-LD) and
// pushed to GBP. `googleLocationId`/`operationId` link the async lifecycle.
model LocalListing {
  id               String             @id @default(cuid())
  tenantId         String
  businessId       String?
  name             String
  // Address/service area (SA SMBs are often area-based, not a street address).
  area             String             @default("")
  phone            String             @default("")
  // GBP categories (primary + additional). JSON array of strings.
  categories       Json?
  // Opening hours, free-form JSON (per-day ranges).
  hours            Json?
  status           LocalListingStatus @default(draft)
  // Google location resource id once created (mock: synthetic).
  googleLocationId String?
  // The async W1 operation that creates/verifies this listing.
  operationId      String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([businessId])
  @@map("local_listings")
}

// A catalog product offered over WhatsApp. priceCents is ZAR cents (BigInt).
model Product {
  id          String   @id @default(cuid())
  tenantId    String
  businessId  String?
  name        String
  description String   @default("")
  priceCents  BigInt   @default(0)
  imageUrl    String?
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([businessId])
  @@map("products")
}

// The WhatsApp order lifecycle.
enum WhatsappOrderStatus {
  draft
  sent
  paid
  fulfilled
  canceled
}

// A tenant-owned order captured over WhatsApp. totalCents is ZAR cents (BigInt).
// `paymentLinkRef` is the PaymentLink id this order was billed through (if any).
model WhatsappOrder {
  id              String              @id @default(cuid())
  tenantId        String
  businessId      String?
  customerContact String
  // Line-item snapshot (productId/name/quantity/priceCents captured at order time).
  items           Json
  totalCents      BigInt              @default(0)
  status          WhatsappOrderStatus @default(draft)
  paymentLinkRef  String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([businessId])
  @@map("whatsapp_orders")
}

// ---------------------------------------------------------------------------
// W6 — GitHub + Vercel per-customer repos & deploys (ENTERPRISE_REVIEW §5.3).
//
// Repo-per-customer, operator-owned: the GitHub App creates one private repo per
// customer site under an operator org (launchdesk-sites/{slug}). Each publish is
// a commit (the rollback target + the agent team's working surface) tied to the
// existing site_versions. GitHub is the SINGLE SOURCE OF TRUTH; the owner never
// sees Git — they see "history" + "undo".
//
// Both tables are tenant-owned → RLS (ENABLE + FORCE + tenant_isolation), the
// same backstop as every other tenant table. Only the Prisma impl touches them
// (DATABASE_URL real); in mock mode the in-memory repo is used.
// ---------------------------------------------------------------------------

// One operator-owned private GitHub repo per customer site. `repoRef` is the
// backend id (mock: synthetic; live: GitHub repo node id / "owner/name").
model SiteRepo {
  id            String   @id @default(cuid())
  tenantId      String
  // The site slug this repo backs (one repo per published site). Unique per
  // tenant so the repo↔site mapping is 1:1 within a tenant.
  slug          String
  // Operator-side repo reference (e.g. "launchdesk-sites/joes-shop").
  repoRef       String
  repoUrl       String
  defaultBranch String   @default("main")
  // The last commit sha we recorded for a publish (mock: synthetic). Lets the
  // owner-facing "history"/"undo" tie a site_version to its commit.
  lastCommitSha String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("site_repos")
}

// The StaticTier deploy lifecycle (Vercel). A deploy is GATED + ASYNC: the
// ActionRouter starts a W1 operation and returns 202; the Vercel webhook (or the
// reconcile cron in mock) settles it to live/failed and updates this row.
enum DeploymentStatus {
  queued
  building
  live
  failed
}

// One deploy attempt for a site. target='static' in W6 (container/K8s are
// Phase 3). `operationId` links the async W1 operation that drives it terminal;
// `url` is the live deployment URL once it settles to `live`.
model Deployment {
  id          String           @id @default(cuid())
  tenantId    String
  slug        String
  // The deploy target tier. W6 ships 'static' only (Vercel); 'container'/'k8s'
  // are Phase 3 (kept as a plain string so future tiers need no enum migration).
  target      String           @default("static")
  status      DeploymentStatus @default(queued)
  url         String?
  // The async W1 operation that settles this deploy (Vercel webhook / cron).
  operationId String?
  // The site_versions version this deploy published (ties deploy↔commit↔version).
  version     Int?
  // The vendor-side deployment id (mock: synthetic; live: Vercel deployment id),
  // used to correlate the inbound Vercel webhook back to this row.
  providerDeploymentId String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([slug])
  @@index([operationId])
  @@index([providerDeploymentId])
  @@map("deployments")
}

// ---------------------------------------------------------------------------
// W5 — Hosting reseller control plane (ENTERPRISE_REVIEW §5.2 + Part 3.A).
//
// Managed (container/K8s) hosting, namespace-per-tenant. The owner answers two
// plain questions (region + named plan); the platform resolves a VETTED plan
// from the catalog (config) and renders the isolation manifest — NEVER a raw
// owner manifest/YAML/env (RCE guard). region/planName/tier are the vetted enum
// STRINGS the server resolved (never free-form). Provisioning runs in the durable
// ProvisioningJob queue (+ reconcile cron), never in the request; the deployment
// carries the state machine and `killSwitch`/`anomalyFlag` cost-abuse guardrails.
//
// Both tables are tenant-owned -> RLS (ENABLE + FORCE + tenant_isolation), the
// same backstop as every other tenant table. Only the Prisma impl touches them
// (DATABASE_URL real); in mock mode the in-memory repo is used.
// ---------------------------------------------------------------------------

// The managed-hosting deployment state machine:
//   requested → provisioning → running → (scaling) → suspended → torn_down | failed
enum HostingDeploymentStatus {
  requested
  provisioning
  running
  scaling
  suspended
  torn_down
  failed
}

// One managed-hosting deployment per (tenant, slug). region/planName/tier are the
// vetted enum strings (server-side allowlist; never free-form). `killSwitch` is
// the per-tenant hard stop; `anomalyFlag` is the billing-anomaly flag. Money
// snapshots are ZAR cents (integer). `operationId` links the async provisioning.
model HostingDeployment {
  id          String                  @id @default(cuid())
  tenantId    String
  slug        String
  region      String
  planName    String
  tier        String
  status      HostingDeploymentStatus @default(requested)
  replicas    Int                     @default(1)
  maxReplicas Int                     @default(1)
  backendRef  String?
  killSwitch  Boolean                 @default(false)
  anomalyFlag Boolean                 @default(false)
  priceCents  Int                     @default(0)
  costCents   Int                     @default(0)
  operationId String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([status])
  @@map("hosting_deployments")
}

// The durable provisioning-queue job lifecycle. Provisioning NEVER runs in the
// request — a verb enqueues a job, the reconcile cron (live: QStash/Inngest)
// runs it against the tier backend, and the job settles the async W1 operation.
enum ProvisioningJobStatus {
  queued
  running
  done
  failed
}

// One unit of provisioning work. `kind` is provision/scale/teardown; `runAfter`
// is the earliest the sweep may pick it up (ms epoch stored as BigInt to match
// the in-memory store + avoid timezone math); `attempts` bounds retries.
model ProvisioningJob {
  id             String                @id @default(cuid())
  tenantId       String
  deploymentId   String
  kind           String
  status         ProvisioningJobStatus @default(queued)
  operationId    String?
  targetReplicas Int?
  attempts       Int                   @default(0)
  // Earliest epoch-ms the reconcile sweep may run this job. BigInt so it matches
  // the in-memory store's Date.now() ms and needs no timezone conversion.
  runAfter       BigInt                @default(0)
  detail         String                @default("")
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([deploymentId])
  @@map("provisioning_jobs")
}

// ---------------------------------------------------------------------------
// W7 — The customer agent team (ENTERPRISE_REVIEW Part 7 / Part 3.C).
//
// The agent team is an ORCHESTRATOR over the existing nine adapters + the one
// ActionRouter — NOT a tenth adapter that can do what it wants. It adds only:
// roles + a job queue (AgentJob) + a per-tenant policy/kill-switch (AgentPolicy);
// metering reuses UsageRecord/TokenWallet (W2). Agents hold ZERO raw credentials
// and ZERO direct push/deploy power; risky actions go through three new gated
// verbs, and the agent NEVER mints its own approval token (an enforced invariant).
//
// Both tables are tenant-owned -> RLS (ENABLE + FORCE + tenant_isolation), the
// same backstop as every other tenant table. Only the Prisma impl touches them
// (DATABASE_URL real); in mock mode the in-memory repo is used. No raw code/diffs/
// secrets live here — code lives in the customer's GitHub repo; payloads are
// referenced by hash (inputRef/resultRef) so they stay token-bindable.
// ---------------------------------------------------------------------------

// The lifecycle of one agent job in the DAG. `awaiting_approval` is the state a
// risky job sits in until the OWNER approves (the agent cannot self-approve);
// `blocked` is the hard halt when the spend cap / wallet cannot cover the next
// step, or the tenant is paused.
enum AgentJobStatus {
  queued
  running
  awaiting_approval
  done
  failed
  blocked
}

// One job in the bounded DAG the Conductor decomposes a trigger into. `role`
// is the agent role (ci_medic / builder / bug_hunter / security_sentinel /
// reviewer / conductor); `trigger` is what spawned the run; `riskTier` maps the
// output to who approves (auto / review / escalate). `parentJobId` forms the DAG
// (no self-loops). `inputRef`/`resultRef` are content hashes/refs (never raw
// code). `prUrl` is the fix/feature PR the job produced. `costMicro` is the
// wallet draw attributed to this job (ZAR micro-cents, BigInt).
model AgentJob {
  id           String         @id @default(cuid())
  tenantId     String
  role         String
  trigger      String
  status       AgentJobStatus @default(queued)
  // auto | review | escalate (server-side enum; the role's output maps to one).
  riskTier     String         @default("review")
  // Content-addressed reference to the job input (e.g. a hashed error log /
  // request), never the raw untrusted text.
  inputRef     String?
  // Reference to the job result (e.g. a mock fix ref / verdict), never raw code.
  resultRef    String?
  // The PR the job opened (agents open PRs, never push direct).
  prUrl        String?
  // DAG edge: the parent job this one was decomposed from (null for the root).
  parentJobId  String?
  // Wallet draw attributed to this job, ZAR micro-cents.
  costMicro    BigInt         @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([parentJobId])
  @@map("agent_jobs")
}

// One policy row per tenant (the kill switch + auto-approve toggle + spend cap).
// `pausedByOwner` halts ALL the tenant's jobs immediately. `autoApproveContent`
// lets AUTO-tier content/copy swaps land without an owner tap. `monthlySpendCapMicro`
// is the hard agent-spend ceiling enforced as a pre-flight between every step
// (in addition to the W2 wallet balance).
model AgentPolicy {
  id                   String   @id @default(cuid())
  tenantId             String   @unique
  pausedByOwner        Boolean  @default(false)
  autoApproveContent   Boolean  @default(true)
  // ZAR micro-cents. 0 = "use the wallet balance as the only ceiling".
  monthlySpendCapMicro BigInt   @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("agent_policies")
}

